# Public, baked into the build at compile time.
# The canonical domain. Used for sitemap, canonical URLs, OG metadata, schema.
# Local dev defaults to http://localhost:3000 when this is unset.
NEXT_PUBLIC_SITE_URL=https://example.com

# Google AdSense client ID, in the format ca-pub-XXXXXXXXXXXXXXXX.
# Leave empty until AdSense approves the site. Ad placeholders render either way.
NEXT_PUBLIC_ADSENSE_CLIENT=
